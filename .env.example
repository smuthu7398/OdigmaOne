# Odigma One — environment template
# Copy to .env and fill in real values. Never commit .env.

# MySQL — use a dedicated user scoped to the odigma_one database only
DATABASE_URL="mysql://odigma:<password>@localhost:3306/odigma_one"
SHADOW_DATABASE_URL="mysql://odigma:<password>@localhost:3306/odigma_one_shadow"

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="<random-32-byte-secret>"
BETTER_AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UPLOADS_DIR="./uploads"

# Seed (first Super Admin account)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="<temporary-password>"
